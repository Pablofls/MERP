# Copia este archivo a .env.local y rellena los valores.

# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-public-key

# Google OAuth — Google Cloud Console > Credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret

# URL pública de la app (obligatorio en producción para validar OAuth redirect)
NEXT_PUBLIC_APP_URL=https://tu-dominio.vercel.app

# Clave de encriptación para refresh tokens de Google (AES-256-GCM)
# Genera una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKENS_ENCRYPTION_KEY=pega-aqui-64-caracteres-hex
